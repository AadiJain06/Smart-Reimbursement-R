generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id              String   @id @default(uuid())
  name            String
  defaultCurrency String
  countryCode     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users         User[]
  expenses      Expense[]
  approvalRules ApprovalRule[]
}

model User {
  id           String   @id @default(uuid())
  email        String
  passwordHash String
  name         String
  /// ADMIN | MANAGER | EMPLOYEE
  role         String
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  managerId    String?
  manager      User?    @relation("ReportsTo", fields: [managerId], references: [id])
  directReports User[]  @relation("ReportsTo")
  createdAt    DateTime @default(now())

  submittedExpenses Expense[]       @relation("ExpenseSubmitter")
  approvalSteps     ApprovalStep[]  @relation("StepApprover")
  approvalLogs      ApprovalLog[]

  @@unique([companyId, email])
  @@index([companyId])
}

model ApprovalRule {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  isDefault   Boolean  @default(false)
  /// JSON string — WorkflowDefinition
  definition  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  expenses Expense[]

  @@index([companyId])
}

model Expense {
  id                      String   @id @default(uuid())
  amount                  Decimal
  currency                String
  amountInCompanyCurrency Decimal
  category                String
  description             String?
  date                    DateTime
  receiptPath             String?
  /// PENDING | APPROVED | REJECTED
  status                  String   @default("PENDING")
  companyId               String
  company                 Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  submitterId             String
  submitter               User     @relation("ExpenseSubmitter", fields: [submitterId], references: [id])
  approvalRuleId          String?
  approvalRule            ApprovalRule? @relation(fields: [approvalRuleId], references: [id])
  workflowPhase           String?       @default("sequential")
  currentBlockIndex       Int           @default(0)
  /// JSON string (OCR metadata)
  metadata                String?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  approvalSteps ApprovalStep[]
  approvalLogs  ApprovalLog[]

  @@index([companyId])
  @@index([submitterId])
  @@index([status])
}

model ApprovalStep {
  id                String    @id @default(uuid())
  expenseId         String
  expense           Expense   @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  blockIndex        Int
  stepIndex         Int
  parallelSlot      Int       @default(0)
  approverUserId    String?
  approver          User?     @relation("StepApprover", fields: [approverUserId], references: [id])
  /// ADMIN | MANAGER | EMPLOYEE when pool-based
  requiredRole      String?
  label             String?
  /// WAITING | PENDING | APPROVED | REJECTED | SKIPPED
  status            String    @default("WAITING")
  decidedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([expenseId])
  @@index([approverUserId])
}

model ApprovalLog {
  id         String   @id @default(uuid())
  expenseId  String
  expense    Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  /// SUBMITTED | APPROVED | REJECTED | ...
  action     String
  comment    String?
  metadata   String?
  createdAt  DateTime @default(now())

  @@index([expenseId])
}
